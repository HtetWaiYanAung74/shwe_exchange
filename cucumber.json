{
    "default": {
        "formatOptions": {
            "snippetInterface": "async-await",
            "logLevel": "debug"
        },
        "dryRun": false,
        "paths": [
            "src/tests/features/*.feature"
        ],
        "require": [
            "src/tests/step-definitions/*.step.ts", "src/tests/**/*.ts"
        ],
        "requireModule": [
            "ts-node/register"
        ],
        "format": [
            "html:reports/cucumber-report.html"
        ]
    }
}